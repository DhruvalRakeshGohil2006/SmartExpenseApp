<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartExpenseApp.Views.retype"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Title="Smart Expense - Confirm PIN"
             BackgroundColor="#7E44E3">

    <Grid VerticalOptions="Center" HorizontalOptions="Fill" Padding="20" RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <Label Grid.Row="0" 
               Text="Confirm PIN" 
               FontSize="20" 
               TextColor="White" 
               VerticalOptions="Center"
               HorizontalOptions="Center" />

        <Entry Grid.Row="1"
               VerticalOptions="Center"
               HorizontalOptions="FillAndExpand"
               Keyboard="Numeric"
               FontSize="40"
               x:Name="PinEntry"/>
        <!-- Added x:Name for the Entry -->

        <!-- Submit Button -->
        <Button Grid.Row="2" 
                Text="Submit" 
                BackgroundColor="#FFFFFF" 
                TextColor="#7E44E3" 
                FontAttributes="Bold" 
                CornerRadius="10" 
                HorizontalOptions="Center" 
                WidthRequest="150" 
                Clicked="OnSubmitClicked" />

        <!-- Prompt Message -->
        <Label Grid.Row="3"
               x:Name="PromptMessage"
               Text=""
               FontSize="16"
               TextColor="White"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               IsVisible="False" />
    </Grid>

</ContentPage>
