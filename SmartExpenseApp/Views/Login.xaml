<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartExpenseApp.Views.NewPage1"
             Title="NewPage1">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Header with Back Button and Title -->
        <HorizontalStackLayout VerticalOptions="Start" HeightRequest="50">
            <Image 
                Source="Resources/Images/back_arrow.png" 
                BackgroundColor="Transparent"
                VerticalOptions="Start" 
                HorizontalOptions="Start"
                HeightRequest="30"
                WidthRequest="20"
                Margin="10">
           
            </Image>
            <Label Text="Login" FontSize="20" FontAttributes="Bold" 
                   VerticalOptions="Center" HorizontalOptions="CenterAndExpand" />
        </HorizontalStackLayout>

        <!-- Email Entry -->
        <Frame CornerRadius="25" Padding="10" BackgroundColor="White" HasShadow="False" BorderColor="Transparent">
            <Entry Placeholder="Email" 
                   HeightRequest="50"
                   FontSize="16"
                   TextColor="Black"
                   Keyboard="Email"
                   BackgroundColor="Transparent" />
        </Frame>

        <!-- Password Entry with Visibility Toggle -->
        <Frame CornerRadius="25" Padding="10" BackgroundColor="White" HasShadow="False" BorderColor="Transparent">
            <Grid>
                <Entry Placeholder="Password" 
                       IsPassword="True"
                       HeightRequest="50"
                       FontSize="16"
                       TextColor="Black"
                       Keyboard="Text"
                       BackgroundColor="Transparent" />
                <ImageButton Source="eye.png"
                             WidthRequest="24"
                             HeightRequest="24"
                             HorizontalOptions="End"
                             VerticalOptions="Center"
                             Margin="0,0,10,0"
                             BackgroundColor="Transparent" />
            </Grid>
        </Frame>

        <!-- Login Button -->
        <Button Text="Login"
                BackgroundColor="#8B5CF6"
                TextColor="White"
                FontAttributes="Bold"
                HeightRequest="50"
                CornerRadius="25"
                Margin="0,20,0,0" />

        <!-- Forgot Password Link -->
        <Label Text="Forgot Password?" FontSize="14" TextColor="#8B5CF6" HorizontalOptions="Center" />

        <!-- Sign Up Link -->
        <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,0">
            <Label Text="Don’t have an account yet?" FontSize="14" TextColor="Gray" />
            <Label Text="Sign Up" FontSize="14" TextColor="#8B5CF6" FontAttributes="Bold" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>