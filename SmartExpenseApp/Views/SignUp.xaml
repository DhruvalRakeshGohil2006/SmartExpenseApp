<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartExpenseApp.Views.SignUp"
             Title="Signup"
             BackgroundColor="White">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Back Arrow -->
            <Image 
            Source="Resources/Images/back_arrow.png" 
            BackgroundColor="Transparent"
            VerticalOptions="Start" 
            HorizontalOptions="Start"
            HeightRequest="30"
            WidthRequest="20"
            Margin="10">
            </Image>

            <!-- Title -->
            <Label Text="Sign Up" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black" />

            <!-- Name Entry -->
            <Frame CornerRadius="25" Padding="10" BorderColor="#E0E0E0" HasShadow="False" BackgroundColor="White">
                <Entry Placeholder="Name" BackgroundColor="Transparent" TextColor="Black" />
            </Frame>

            <!-- Mobile Number Entry -->
            <Frame CornerRadius="25" Padding="10" BorderColor="#E0E0E0" HasShadow="False" BackgroundColor="White">
                <Entry Placeholder="Mobile Number" Keyboard="Telephone" BackgroundColor="Transparent" TextColor="Black" />
            </Frame>

            <!-- Email Entry -->
            <Frame CornerRadius="25" Padding="10" BorderColor="#E0E0E0" HasShadow="False" BackgroundColor="White">
                <Entry Placeholder="Email" Keyboard="Email" BackgroundColor="Transparent" TextColor="Black" />
            </Frame>

            <!-- Password Entry -->
            <Frame CornerRadius="25" Padding="10" BorderColor="#E0E0E0" HasShadow="False" BackgroundColor="White">
                <Grid>
                    <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" BackgroundColor="Transparent" TextColor="Black" />
                    <ImageButton Source="eye_icon.png" HorizontalOptions="End" VerticalOptions="Center"  BackgroundColor="Transparent" />
                </Grid>
            </Frame>

            <!-- Terms and Conditions -->
            

            <!-- Sign Up Button -->
            <Button Text="Sign Up" BackgroundColor="#7B4FFF" TextColor="White" CornerRadius="25" HeightRequest="50" />

            <!-- Login Link -->
            <Label HorizontalOptions="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Already have an account? " TextColor="Black" />
                        <Span Text="Login" TextColor="Blue" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
