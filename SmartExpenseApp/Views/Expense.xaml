<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartExpenseApp.Views.Expense"
             Title="Expense"
             BackgroundColor="#FF3C4A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Red Section -->
            <RowDefinition Height="*" />
            <!-- White Section -->
        </Grid.RowDefinitions>

        <!-- Red Background with Amount Display -->
        <VerticalStackLayout Grid.Row="0" Padding="10,450,30,10" VerticalOptions="StartAndExpand">
            <Label Text="How much?" FontSize="20" TextColor="#FCFCFC" 
                   HorizontalOptions="Start" FontAttributes="Bold"/>
            <Entry Placeholder="₹0" FontSize="54" Keyboard="Numeric" WidthRequest="200" TextColor="#FCFCFC" FontAttributes="Bold"
                   HorizontalOptions="Start"/>
        </VerticalStackLayout>

        <!-- White Section -->
        <VerticalStackLayout BackgroundColor="White" Grid.Row="1" VerticalOptions="End" Padding="15">
            <Frame CornerRadius="20" BackgroundColor="White"  Padding="20" Margin="0">
                <VerticalStackLayout Spacing="15">
                    <!-- Category Picker -->
                    <Picker Title="Category" FontSize="16" TextColor="Black">
                        <Picker.Items>
                            <x:String>Grocery</x:String>
                            <x:String>Rent</x:String>
                            <x:String>Utilities</x:String>
                            <x:String>Dining</x:String>
                            <x:String>Shopping</x:String>
                        </Picker.Items>
                    </Picker>

                    <!-- Description Entry -->
                    <Entry Placeholder="Description" FontSize="16" TextColor="Black"/>

                    <!-- Wallet Picker -->
                    <Picker Title="Wallet" FontSize="16" TextColor="Black">
                        <Picker.Items>
                            <x:String>Bank</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Frame>

            <!-- Continue Button -->
            <Button Text="Continue" 
                    Margin="20"  
                    BackgroundColor="#7F3DFF" 
                    TextColor="White" 
                    CornerRadius="25"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="End"
                    HeightRequest="50"
                    WidthRequest="320"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
