<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartExpenseApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartExpenseApp.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#7F3DFF"
    Shell.TabBarBackgroundColor="Transparent"
    Shell.TabBarForegroundColor="#7F3DFF"
    Shell.TabBarTitleColor="#7F3DFF"
    Shell.TabBarUnselectedColor="Gray"
    Shell.TitleColor="#FFFFFF"
    Title="SmartExpenseApp">

    <ShellContent Route="login" ContentTemplate="{DataTemplate local:Login}" />
    <!--<ShellContent Route="signup" ContentTemplate="{DataTemplate local:SignUp}" />-->
    
    <TabBar>
        <Tab Title="Home" Route="home" Icon="home_bottomicon.png">
            <ShellContent ContentTemplate="{DataTemplate local:HomeScreen}" />
        </Tab>

        <Tab Title="Transactions" Route="transactions" Icon="transaction_bottomicon.png">
            <ShellContent ContentTemplate="{DataTemplate local:Transaction}" />
        </Tab>

        <Tab Title="Trends" Route="trends" Icon="graphstrends_bottomicon.png">
            <ShellContent ContentTemplate="{DataTemplate local:GraphAndTrends}" />
        </Tab>

        <Tab Title="Profile" Route="profile" Icon="profile_bottomicon.png">
            <ShellContent ContentTemplate="{DataTemplate local:Profile}" />
        </Tab>
    </TabBar>

</Shell>
